{
  "extends": "@tsconfig/node22/tsconfig.json",
  "include": ["src/lib.ts", "src/cli.ts", "src/mcp-server.ts"],
  "compilerOptions": {
    "outDir": "dist-tools",
    "noEmit": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  }
}
